flow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense\n","\n","# Input image dimensions\n","img_height = 150\n","img_width = 150\n","channels = 3\n","\n","# Binary classification problem (0 or 1)\n","num_classes = 1\n","\n","cnn_model = Sequential([\n","    Input(shape=(img_height, img_width, channels)),\n","\n","    # 1st Convolution block: learns low-level features (edges, lines)\n","    Conv2D(32, (3, 3), activation='relu'),\n","    MaxPooling2D(pool_size=(2, 2)),\n","    \n","    # 2nd Convolution block: learns mid-level features (textures, shapes)\n","    Conv2D(64, (3, 3), activation='relu'),\n","    MaxPooling2D(pool_size=(2, 2)),\n","\n","    # 3rd Convolution block: learns high-level features (object parts)\n","    Conv2D(128, (3, 3), activation='relu'),\n","    MaxPooling2D(pool_size=(2, 2)),\n","\n","    # Flatten 2D feature maps into 1D feature vector\n","    Flatten(),\n","\n","    # Fully connected layer for decision making\n","    Dense(128, activation='relu'),\n","\n","    # Output layer for binary classification (sigmoid gives probability)\n","    Dense(num_classes, activation='sigmoid')\n","])\n","\n","# Compile model\n","# binary_crossentropy is used for binary classification (0/1)\n","cnn_model.compile(\n","    optimizer='adam',\n","    loss='binary_crossentropy',\n","    metrics=['accuracy']\n",")\n","\n","# Model architecture and parameter count\n","cnn_model.summary()"]},{"cell_type":"markdown","id":"04d027cb","metadata":{"papermill":{"duration":0.006423,"end_time":"2026-05-26T18:55:45.264726+00:00","exception":false,"start_time":"2026-05-26T18:55:45.258303+00:00","status":"completed"},"tags":[]},"source":["During training:\n","\n","* Filters start randomly\n","* CNN compares predictions with true labels\n","* Errors are calculated\n","* Filters are updated gradually\n","\n","Eventually:\n","\n","* good filters emerge automatically\n","* network learns meaningful patterns"]},{"cell_type":"code","execution_count":3,"id":"ab0b30ed","meta