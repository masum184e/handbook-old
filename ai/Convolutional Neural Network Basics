;5;34m262,400\u001b[0m │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ dense_2 (\u001b[38;5;33mDense\u001b[0m)                 │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m64\u001b[0m)             │        \u001b[38;5;34m16,448\u001b[0m │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ dense_3 (\u001b[38;5;33mDense\u001b[0m)                 │ (\u001b[38;5;45mNone\u001b[0m, \u001b[38;5;34m1\u001b[0m)              │            \u001b[38;5;34m65\u001b[0m │\n","└─────────────────────────────────┴────────────────────────┴───────────────┘\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Total params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">69,399,937</span> (264.74 MB)\n","</pre>\n"],"text/plain":["\u001b[1m Total params: \u001b[0m\u001b[38;5;34m69,399,937\u001b[0m (264.74 MB)\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">69,399,937</span> (264.74 MB)\n","</pre>\n"],"text/plain":["\u001b[1m Trainable params: \u001b[0m\u001b[38;5;34m69,399,937\u001b[0m (264.74 MB)\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n","</pre>\n"],"text/plain":["\u001b[1m Non-trainable params: \u001b[0m\u001b[38;5;34m0\u001b[0m (0.00 B)\n"]},"metadata":{},"output_type":"display_data"}],"source":["# Multilayer Perceptron (MLP) for binary image classification\n","# NOTE: Images are flattened before feeding into Dense layers\n","# This model does NOT use convolution, so it ignores spatial structure\n","\n","import tensorflow as tf\n","from tensorflow.keras.models import Sequential\n","from tensorflow.keras.layers import Input, Flatten, Dense\n","\n","# Input image dimensions\n","img_height = 150\n","img_width = 150\n","channels = 3\n","\n","# Binary classification problem (0 or 1)\n","num_classes = 1\n","\n","# Build MLP model\n","mlp_model = Sequential([\n","    \n","    # Convert 3D image (150x150x3) into 1D vector (67500 features)\n","    Input(shape=(img_height, img_width, channels)),\n","\n","    Flatten(),\n","\n","    # Fully connected hidden layers\n","    Dense(1024, activation='relu'),\n","    Dense(256, activation='relu'),\n","    Dense(64, activation='relu'),\n","\n","    # Output layer for binary classification (sigmoid gives probability)\n","    Dense(num_classes, activation='sigmoid')\n","])\n","\n","# Compile the model\n","mlp_model.compile(\n","    optimizer='adam',\n","    loss='binary_crossentropy',\n","    metrics=['accuracy']\n",")\n","\n","# Model architecture and parameter count\n","mlp_model.summary()"]},{"cell_type":"markdown","id":"f7d8cb79","metadata":{"papermill":{"duration":0.005875,"end_time":"2026-05-26T18:55:45.130938+00:00","exception":false,"start_time":"2026-05-26T18:55:45.125063+00:00","status":"completed"},"tags":[]},"source":["### Total params: 69,399,937\n","\n","This is the total number of **learnable numbers (weights + biases)** in your model.\n","\n","* Each “parameter” is a single floating-point value.\n","* So your model has about **69.4 million values it uses to make predictions**.\n","* Bigger models → more capacity, but also more memory and computation needed.\n","\n","### Trainable params: 69,399,937\n","\n","These are the parameters that will be **updated during training** using backpropagation.\n","\n","* In your case, **all parameters are trainable**.\n","* That means nothing is frozen.\n","\n","Example of “non-trainable” parts could be:\n","\n","* Pretrained layers you froze\n","* Fixed embeddings\n","* BatchNorm moving averages (in some frameworks)\n","\n","### Non-trainable params: 0\n","\n","This means:\n","\n","* There are **no frozen or fixed weights**\n","* Everything in the model is being learned\n","\n","### (264.74 MB)\n","\n","This is the **approximate memory required to store the parameters**.\n","\n","Why so large?\n","\n","Most models use `float32`:\n","\n","* 1 parameter = 4 bytes\n","* 69,399,937 × 4 bytes ≈ 277 MB (close to your reported ~264 MB after internal rounding/format differences)\n","\n","### In simple terms\n","\n","You have a **~69M-parameter neural network**, and:\n","\n","* It is fully trainable\n","* It needs ~250–280 MB just to store weights\n","* It’s roughly in the range of a **mid-size deep learning model**\n","\n"]},{"cell_type":"code","execution_count":2,"id":"b0682907","metadata":{"execution":{"iopub.execute_input":"2026-05-26T18:55:45.145051Z","iopub.status.busy":"2026-05-26T18:55:45.143963Z","iopub.status.idle":"2026-05-26T18:55:45.249452Z","shell.execute_reply":"2026-05-26T18:55:45.248449Z"},"papermill":{"duration":0.114466,"end_time":"2026-05-26T18:55:45.251201+00:00","exception":false,"start_time":"2026-05-26T18:55:45.136735+00:00","status":"completed"},"tags":[]},"outputs":[{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"sequential_1\"</span>\n","</pre>\n"],"text/plain":["\u001b[1mModel: \"sequential_1\"\u001b[0m\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Co