    "from tensorflow.keras.layers import Input, Conv2D, Dense, Flatten, TimeDistributed, Lambda\n",
    "from tensorflow.keras.models import Model\n",
    "\n",
    "def build_faster_rcnn(num_classes=2, num_anchors=9):\n",
    "\n",
    "    # IMAGE INPUT\n",
    "    image_input = Input(\n",
    "        shape=(600, 600, 3),\n",
    "        name=\"image_input\"\n",
    "    )\n",
    "\n",
    "    # BACKBONE NETWORK (VGG16)\n",
    "    backbone = tf.keras.applications.VGG16(\n",
    "        include_top=False,\n",
    "        weights='imagenet',\n",
    "        input_tensor=image_input\n",
    "    )\n",
    "\n",
    "    feature_map = backbone.output\n",
    "    # shape ~ (None, 37, 37, 512)\n",
    "\n",
    "    # REGION PROPOSAL NETWORK (RPN)\n",
    "    rpn = Conv2D(\n",
    "        512,\n",
    "        (3, 3),\n",
    "        padding='same',\n",
    "        activation='relu',\n",
    "        name='rpn_conv'\n",
    "    )(feature_map)\n",
    "\n",
    "    # Objectness score\n",
    "    rpn_class = Conv2D(\n",
    "        num_anchors * 2,\n",
    "        (1, 1),\n",
    "        activation='softmax',\n",
    "        name='rpn_class'\n",
    "    )(rpn)\n",
    "\n",
    "    # Bounding box regression\n",
    "    rpn_bbox = Conv2D(\n",
    "        num_anchors * 4,\n",
    "        (1, 1),\n",
    "        activation='linear',\n",
    "        name='rpn_bbox'\n",
    "    )(rpn)\n",
    "\n",
    "    # ROI INPUT: (Normally generated from RPN + NMS)\n",
    "\n",
    "    roi_input = Input(\n",
    "        shape=(64, 4),\n",
    "        name='roi_input'\n",
    "    )\n",
    "\n",
    "    # ROI POOLING\n",
    "    pooled_rois = Lambda(\n",
    "        roi_wrapper,\n",
    "        output_shape=roi_output_shape,\n",
    "        name='roi_pooling'\n",
    "    )([feature_map, roi_input])\n",
    "\n",
    "    # FAST R-CNN HEAD\n",
    "    x = Flatten()(pooled_rois)\n",
    "\n",
    "    x = Dense(4096, activation='relu')(x)\n",
    "    x = Dense(4096, activation='relu')(x)\n",
    "\n",
    "    # Classification head\n",
    "    class_output = Dense(\n",
    "        num_classes,\n",
    "        activation='softmax',\n",
    "        name='class_output'\n",
    "    )(x)\n",
    "\n",
    "    # Bounding box head\n",
    "    bbox_output = Dense(\n",
    "        num_classes * 4,\n",
    "        activation='linear',\n",
    "        name='bbox_output'\n",
    "    )(x)\n",
    "\n",
    "    # FINAL MODEL\n",
    "    model = Model(\n",
    "        inputs=[image_input, roi_input],\n",
    "        outputs=[\n",
    "            rpn_class,\n",
    "            rpn_bbox,\n",
    "            class_output,\n",
    "            bbox_output\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    return model"
   ]
