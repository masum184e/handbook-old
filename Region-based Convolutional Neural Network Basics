age_path)\n\n    if image is None:\n        return [], []\n\n    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n\n    # 1. Region Proposal Generation With Selective Search\n    proposals = get_region_proposals(image_rgb)\n\n    features = []\n    labels = []\n\n    for (x, y, w, h) in proposals:\n\n        roi = image_rgb[y:y+h, x:x+w]\n\n        if roi.size == 0:\n            continue\n\n        roi_pil = Image.fromarray(roi)\n\n        # 2. Warp Candidate Regions\n        input_tensor = transform(roi_pil).unsqueeze(0).to(device)\n\n        # 3. CNN Feature Extraction with AlexNet\n        with torch.no_grad():\n            feat = alexnet(input_tensor)\n\n        feat = feat.squeeze().cpu().numpy()\n\n        features.append(feat)\n        labels.append(label)\n\n    return features, labels","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-28T08:52:21.967811Z","iopub.execute_input":"2026-05-28T08:52:21.968981Z","iopub.status.idle":"2026-05-28T08:52:21.980351Z","shell.execute_reply.started":"2026-05-28T08:52:21.968929Z","shell.execute_reply":"2026-05-28T08:52:21.978798Z"}},"outputs":[],"execution_count":9},{"cell_type":"code","source":"# Build Dataset\nimport os\nimport numpy as np\nfrom tqdm import tqdm # add smart progress bars to loops and iterables\nimport cv2\n\ncats_dir = \"/kaggle/input/datasets/tongpython/cat-and-dog/training_set/training_set/cats\"\ndogs_dir = \"/kaggle/input/datasets/tongpython/cat-and-dog/training_set/training_set/dogs\"\n\nX, y = [], []\n\n\n# Cats\ncat_images = os.listdir(cats_dir)[:20]\n\nfor img_name in tqdm(cat_images):\n    path = os.path.join(cats_dir, img_name)\n\n    feats, labels = extract_features(path, 0)\n\n    X.extend(feats)\n    y.extend(labels)\n\n# Dogs\ndog_images = os.listdir(dogs_dir)[:20]\n\nfor img_name in tqdm(dog_images):\n    path = os.path.join(dogs_dir, img_name)\n\n    feats, labels = extract_features(path, 1)\n\n    X.extend(feats)\n    y.extend(labels)\n\nX = np.array(X)\ny = np.arra