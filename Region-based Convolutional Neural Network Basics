sy":"2026-05-28T09:11:06.565131Z","iopub.execute_input":"2026-05-28T09:11:06.565458Z","iopub.status.idle":"2026-05-28T09:11:06.572027Z","shell.execute_reply.started":"2026-05-28T09:11:06.565430Z","shell.execute_reply":"2026-05-28T09:11:06.570855Z"}},"outputs":[],"execution_count":15},{"cell_type":"code","source":"\ndef non_max_suppression(boxes, scores, iou_thresh=0.3):\n    if len(boxes) == 0:\n        return []\n\n    boxes = np.array(boxes)\n    scores = np.array(scores)\n\n    x1, y1, x2, y2 = boxes[:,0], boxes[:,1], boxes[:,2], boxes[:,3]\n    areas = (x2 - x1) * (y2 - y1)\n\n    order = scores.argsort()[::-1]\n    keep = []\n\n    while len(order) > 0:\n        i = order[0]\n        keep.append(i)\n\n        xx1 = np.maximum(x1[i], x1[order[1:]])\n        yy1 = np.maximum(y1[i], y1[order[1:]])\n        xx2 = np.minimum(x2[i], x2[order[1:]])\n        yy2 = np.minimum(y2[i], y2[order[1:]])\n\n        w = np.maximum(0, xx2 - xx1)\n        h = np.maximum(0, yy2 - yy1)\n\n        iou_list = []\n        for j in order[1:]:\n            iou_list.append(compute_iou(\n                (x1[i], y1[i], x2[i], y2[i]),\n                (x1[j], y1[j], x2[j], y2[j])\n            ))\n        iou = np.array(iou_list)\n\n        order = order[np.where(iou <= iou_thresh)[0] + 1]\n\n    return keep","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-28T09:11:08.945902Z","iopub.execute_input":"2026-05-28T09:11:08.946233Z","iopub.status.idle":"2026-05-28T09:11:08.955818Z","shell.execute_reply.started":"2026-05-28T09:11:08.946201Z","shell.execute_reply":"2026-05-28T09:11:08.954802Z"}},"outputs":[],"execution_count":16},{"cell_type":"code","source":"# Read image (OpenCV loads BGR by default)\nimage_path = \"/kaggle/input/datasets/tongpython/cat-and-dog/test_set/test_set/dogs/dog.4003.jpg\"\nimage_bgr = cv2.imread(image_path)\nimage_rgb = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2RGB)\n\n# Generate region proposals\nproposals = get_region_proposals(image_rgb)\n\nboxes = []\nscores = []\npreds = []\n\nfor (x, y, w, h) in proposals:\n\n    # Extract ROI\n    roi = image_rgb[y:y + h, x:x + w]\n\n    if roi.size == 0:\n        continue\n\n    # Convert to PIL image for transform\n    roi = Image.fromarray(roi)\n    tensor = transform(roi).unsqueeze(0).to(device)\n\n    # Feature extraction using AlexNet\n    with torch.no_grad():\n        feat = alexnet(tensor)\n\n    # Flatten feature vector\n    feat = feat.squeeze().cpu().numpy().reshape(1, -1)\n\n    # Classification\n    pred = clf.predict(feat)[0]\n    score = clf.decision_function(feat)[0]\n\n    # Store results\n    boxes.append((x, y, x + w, y + h))\n    scores.append(score)\n    preds.append(pred)\n\n# If no proposals found\nif len(boxes) == 0:\n    print(\"No objects found\")\n\n# Apply Non-Max Suppression\nkeep = non_max_suppression(boxes, scores, 0.3)\nbest = keep[0]\n\n# Get best detection\nx1, y1, x2, y2 = boxes[best]\nlabel = \"Dog\" if preds[best] == 1 else \"Cat\"\n\n# Draw bounding box\ncv2.rectangle(image_rgb, (x1, y1), (x2, y2), (0, 255, 0), 2)\n\ncv2.putText(\n    image_rgb,\n    label,\n    (x1, y1 - 10),\n    cv2.FONT_HERSHEY_SIMPLEX,\n    1,\n    (0, 255, 0),\n    2\n)\n\n# Display result\nplt.figure(figsize=(8, 6))\nplt.imshow(image_rgb)\nplt.axis(\"off\")\nplt.title(f\"Prediction: {label}\")\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-28T09:13:51.311640Z","iopub.execute_input":"2026-05-28T09:13:51.311986Z","iopub.status.idle":"2026-05-28T09:13:53.913239Z","shell.execute_reply.started":"2026-05-28T09:13:51.311956Z","shell.execute_reply":"2026-05-28T09:13:53.912176Z"}},"outputs":[{"name":"stderr","text":"/usr/local/lib/python3.12/dist-packages/skimage/feature/texture.py:385: UserWarning: Applying `local_binary_pattern` to floating-point images may give unexpected results when small numerical differences between adjacent pixels are present. It is recommended to use this function with images of integer dtype.\n  warnings.warn(\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 800x600 with 1 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":23},{"cell_type":"markdown","source":"## Example Workthrough\n\n**Detecting Animals in an Image**\n\nSuppose we have this image:\n\n* a dog sitting on grass\n* a ball nearby\n\n### Region Proposals\n\nSelective Search creates 2000 candidate boxes.\n\n| Proposal | Possible Content |\n| -------- | ---------------- |\n| Box A    | Dog face         |\n| Box B    | Whole dog        |\n| Box C    | Ball             |\n| Box D    | Grass only       |\n\n### Resize Each Proposal\n\nEach region becomes:\n\n$$\n227 \\times 227\n$$\n\n### CNN Feature Extraction\n\nThe CNN extracts features.\n\n#### Dog region features\n\nThe CNN learns patterns such as:\n\n* fur texture\n* ears\n* eyes\n* body shape\n\n#### Ball region features\n\nThe CNN learns:\n\n* circular shape\n* color patterns\n\n### Classification\n\nThe SVM classifiers output scores.\n\n| Region | Dog Score | Ball Score | Background |\n| ------ | --------- | ---------- | ---------- |\n| A      | 0.95      | 0.01       | 0.04       |\n| B      | 0.98      | 0.00       | 0.02       |\n| C      | 0.02      | 0.91       | 0.07       |\n| D      | 0.01      | 0.00       | 0.99       |\n\n### Non-Maximum Suppression (NMS)\n\nMany boxes overlap around the same object.\n\nR-CNN keeps the best one.\n\nExample:\n\n* 5 boxes around dog\n* Keep highest confidence box\n* Remove duplicates\n\nThis process is called:\n\n### Final Output\n\nThe system outputs:\n\n```text\nDog — 98%\nBall — 91%\n```\n\nwith final bounding boxes.\n\n## Evolution After R-CNN\n\n### Fast R-CNN\n\nImproved speed by:\n\n* running CNN only once on full image\n* extracting region features from feature maps\n\nMuch faster.\n\n### Faster R-CNN\n\nIntroduced:\n\n* Region Proposal Network (RPN)\n\nNo need for Selective Search.\n\nReal-time-ish performance.\n\n### Mask R-CNN\n\nExtended Faster R-CNN by adding:\n\n* pixel-level segmentation masks\n\nUsed in advanced vision tasks.\n\n### Comparison\n\n| Method       | Proposal Method               | Speed       |\n| ------------ | ----------------------------- | ----------- |\n| R-CNN        | Selective Search              | Slow        |\n| Fast R-CNN   | Selective Search + shared CNN | Faster      |\n| Faster R-CNN | RPN                           | Much Faster |\n| Mask R-CNN   | RPN + masks                   | Advanced    |\n\n## Charecterstics\n\n### Advantages:\n\n1. Much higher accuracy than traditional methods\n    * Older methods: `HOG + sliding windows`\n    * R-CNN learned deep features automatically.\n2. Reduced exhaustive search\n    * Instead of millions of windows: `Only ~2000 proposals`\n3. CNN feature learning\n    * Deep features outperform hand-crafted features.\n\n### Limitations of R-CNN\n\n1. Very slow\n    * For each image: `2000 CNN forward passes`\n    * Each proposal is processed independently. Time: `≈47 seconds/image` (on original hardware)\n2. Large storage requirement\n    * Extracted features were stored on disk: `hundreds of GB`\n3. Multi-stage training\n    * CNN + SVM + regression trained separately. Complex pipeline.\n4. No end-to-end learning\n    * Entire system is not optimized jointly.\n\n### Mathematical Perspective\n\nThe CNN learns a function:\n\n$$\nf(x) \\rightarrow y\n$$\n\nwhere:\n\n* x = image region\n* y = feature representation or class probabilities\n\nFor classification, the softmax function is often used:\n$$\nP(y_i)=\\frac{e^{z_i}}{\\sum_j e^{z_j}}\n$$\nThis converts scores into probabilities.\n\n### Key Takeaways\n\n> “Use CNNs on proposed object regions instead of scanning everything.”\n\nIts major innovations:\n\n* region proposals\n* CNN feature extraction\n* object-wise classification\n\nEven though newer methods are faster, R-CNN is historically very important in modern Computer Vision and deep learning.","metadata":{}}]}