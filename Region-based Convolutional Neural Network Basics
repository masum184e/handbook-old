    "from torchvision import transforms\n",
    "\n",
    "def extract_features(image_path, label):\n",
    "    image = cv2.imread(image_path)\n",
    "\n",
    "    if image is None:\n",
    "        return [], []\n",
    "\n",
    "    image_rgb = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "    # 1. Region Proposal Generation With Selective Search\n",
    "    proposals = get_region_proposals(image_rgb)\n",
    "\n",
    "    features = []\n",
    "    labels = []\n",
    "\n",
    "    for (x, y, w, h) in proposals:\n",
    "\n",
    "        roi = image_rgb[y:y+h, x:x+w]\n",
    "\n",
    "        if roi.size == 0:\n",
    "            continue\n",
    "\n",
    "        roi_pil = Image.fromarray(roi)\n",
    "\n",
    "        # 2. Warp Candidate Regions\n",
    "        input_tensor = transform(roi_pil).unsqueeze(0).to(device)\n",
    "\n",
    "        # 3. CNN Feature Extraction with AlexNet\n",
    "        with torch.no_grad():\n",
    "            feat = alexnet(input_tensor)\n",
    "\n",
    "        feat = feat.squeeze().cpu().numpy()\n",
    "\n",
    "        features.append(feat)\n",
    "        labels.append(label)\n",
    "\n",
    "    return features, labels"
   ]
