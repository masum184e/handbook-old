    "import selectivesearch\n",
    "\n",
    "def get_region_proposals(image):\n",
    "\n",
    "    _, regions = selectivesearch.selective_search(\n",
    "        image,\n",
    "        scale=500,\n",
    "        sigma=0.9,\n",
    "        min_size=10\n",
    "    )\n",
    "\n",
    "    candidates = []\n",
    "\n",
    "    for r in regions:\n",
    "\n",
    "        if r['rect'] in candidates:\n",
    "            continue\n",
    "\n",
    "        x, y, w, h = r['rect']\n",
    "\n",
    "        if w * h < 2000:\n",
    "            continue\n",
    "\n",
    "        candidates.append((x, y, x+w, y+h))\n",
    "\n",
    "    return candidates[:64]"
   ]
  },
