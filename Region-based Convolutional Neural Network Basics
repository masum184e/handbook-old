    "import tensorflow as tf\n",
    "\n",
    "def roi_pooling(feature_map, rois, pool_size=7, num_rois=64):\n",
    "\n",
    "    outputs = []\n",
    "\n",
    "    h = tf.cast(tf.shape(feature_map)[1], tf.float32)\n",
    "    w = tf.cast(tf.shape(feature_map)[2], tf.float32)\n",
    "\n",
    "    for i in range(num_rois):\n",
    "\n",
    "        x1, y1, x2, y2 = rois[i]\n",
    "\n",
    "        boxes = [[\n",
    "            y1 / h,\n",
    "            x1 / w,\n",
    "            y2 / h,\n",
    "            x2 / w\n",
    "        ]]\n",
    "\n",
    "        pooled = tf.image.crop_and_resize(\n",
    "            feature_map,\n",
    "            boxes=boxes,\n",
    "            box_indices=[0],\n",
    "            crop_size=(pool_size, pool_size)\n",
    "        )\n",
    "\n",
    "        outputs.append(pooled)\n",
    "\n",
    "    return tf.concat(outputs, axis=0)\n"
   ]
