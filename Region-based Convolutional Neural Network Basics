    "import selectivesearch\n",
    "\n",
    "def get_region_proposals(image):\n",
    "    _, regions = selectivesearch.selective_search(\n",
    "        image,\n",
    "        scale=500, # Controls the size of image clusters in the initial segmentation.\n",
    "        sigma=0.9, # Gaussian smoothing parameter applied before segmentation\n",
    "        min_size=10 # Minimum allowed region size (in pixels).\n",
    "    )\n",
    "\n",
    "    candidates = []\n",
    "\n",
    "    for r in regions:\n",
    "        if r['rect'] in candidates:\n",
    "            continue\n",
    "\n",
    "        x, y, w, h = r['rect']\n",
    "\n",
    "        if w * h < 2000:\n",
    "            continue\n",
    "\n",
    "        candidates.append((x, y, w, h))\n",
    "\n",
    "    return candidates[:50]\n"
   ]
